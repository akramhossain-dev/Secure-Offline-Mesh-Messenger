root = true

# ─────────────────────────────────────────────────────────────────────────────
# All files
# ─────────────────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# ─────────────────────────────────────────────────────────────────────────────
# Kotlin files
# ─────────────────────────────────────────────────────────────────────────────
[*.kt]
indent_size = 4
max_line_length = 120
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_import-ordering = enabled

# ─────────────────────────────────────────────────────────────────────────────
# Kotlin Gradle scripts
# ─────────────────────────────────────────────────────────────────────────────
[*.kts]
indent_size = 4
max_line_length = 120

# ─────────────────────────────────────────────────────────────────────────────
# XML files (resources, manifests, layouts)
# ─────────────────────────────────────────────────────────────────────────────
[*.xml]
indent_size = 4
max_line_length = 120

# ─────────────────────────────────────────────────────────────────────────────
# JSON files
# ─────────────────────────────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────────────
# YAML / TOML
# ─────────────────────────────────────────────────────────────────────────────
[*.{yaml,yml,toml}]
indent_size = 2

# ─────────────────────────────────────────────────────────────────────────────
# Markdown
# ─────────────────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off
