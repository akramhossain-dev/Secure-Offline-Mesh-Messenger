<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Controls which data is included in cloud backup and device-to-device transfer.
    Privacy-sensitive data is excluded.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude DataStore preferences -->
        <exclude domain="sharedpref" path="mesh_preferences" />
        <!-- Exclude KeyStorage SharedPreferences (AES-encrypted EC key material) -->
        <exclude domain="sharedpref" path="secure_key_store_prefs" />
        <!-- Exclude all databases -->
        <exclude domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Exclude all sensitive data from device-to-device transfers -->
        <exclude domain="sharedpref" path="mesh_preferences" />
        <!-- Exclude KeyStorage SharedPreferences (AES-encrypted EC key material) -->
        <exclude domain="sharedpref" path="secure_key_store_prefs" />
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
