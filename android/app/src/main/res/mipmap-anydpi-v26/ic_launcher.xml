<?xml version="1.0" encoding="utf-8"?>
<!--
    Emergency Connect — Adaptive Icon descriptor (API 26+)
    Foreground: ic_launcher_foreground (shield + mesh, transparent bg)
    Background: ic_launcher_background (solid deep indigo)
    The system clips and masks this to the device's chosen icon shape.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <foreground android:drawable="@drawable/ic_launcher_foreground" />
</adaptive-icon>
