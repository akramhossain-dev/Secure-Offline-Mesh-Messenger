<?xml version="1.0" encoding="utf-8"?>
<!--
    Emergency Connect — Splash Branding Image
    Shown at the bottom of the Android 12+ system splash screen via
    android:windowSplashScreenBrandingImage.

    Design: Abstract horizontal mesh-network graphic — 5 nodes of varying
    sizes connected by teal lines, with the central hub double-ringed.
    The visual language directly mirrors the shield logo above it and
    conveys "connected mesh" without needing rendered text paths.

    240×60 viewport. Network centred vertically at y=30.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="240dp"
    android:height="60dp"
    android:viewportWidth="240"
    android:viewportHeight="60">

    <!-- ── Connection lines ─────────────────────────────────────────────── -->
    <path
        android:strokeColor="#5ADFF0"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="
            M44,30 L82,30
            M90,30 L110,30
            M130,30 L150,30
            M158,30 L196,30
            M90,30 L110,20
            M110,20 L130,30
            M130,30 L150,20
            M150,20 L158,30" />

    <!-- ── Far-left outer node ───────────────────────────────────────────── -->
    <path
        android:fillColor="#4F4BD4"
        android:pathData="M38,30m-6,0a6,6 0,1 1,12 0a6,6 0,1 1,-12 0" />

    <!-- ── Left secondary node ──────────────────────────────────────────── -->
    <path
        android:fillColor="#7674DC"
        android:pathData="M86,30m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0" />

    <!-- ── Upper-left relay node ─────────────────────────────────────────── -->
    <path
        android:fillColor="#8B89F9"
        android:pathData="M110,20m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />

    <!-- ── Upper-right relay node ────────────────────────────────────────── -->
    <path
        android:fillColor="#8B89F9"
        android:pathData="M150,20m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />

    <!-- ── Central hub — outer glow ring ────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#4F4BD4"
        android:strokeWidth="1.5"
        android:pathData="M120,30m-14,0a14,14 0,1 1,28 0a14,14 0,1 1,-28 0" />
    <!-- Hub fill -->
    <path
        android:fillColor="#8B89F9"
        android:pathData="M120,30m-9,0a9,9 0,1 1,18 0a9,9 0,1 1,-18 0" />
    <!-- Hub inner dot -->
    <path
        android:fillColor="#C4C3EE"
        android:pathData="M120,30m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0" />

    <!-- ── Right secondary node ──────────────────────────────────────────── -->
    <path
        android:fillColor="#7674DC"
        android:pathData="M154,30m-4,0a4,4 0,1 1,8 0a4,4 0,1 1,-8 0" />

    <!-- ── Far-right outer node ──────────────────────────────────────────── -->
    <path
        android:fillColor="#4F4BD4"
        android:pathData="M202,30m-6,0a6,6 0,1 1,12 0a6,6 0,1 1,-12 0" />

</vector>
