<?xml version="1.0" encoding="utf-8"?>
<!--
    Emergency Connect — Splash Logo / System Animated Icon
    Used as:
      - windowSplashScreenAnimatedIcon in Theme.OfflineEmergencyMesh.Splash
      - Compose SplashScreen logo mark (shown inside the ripple container)

    Design: Deep indigo background circle with shield + mesh-node symbol.
    The circle background is intentionally baked in so the system splash
    icon renders consistently before windowSplashScreenIconBackgroundColor
    is applied, and so the in-Compose version is self-contained.

    108×108 viewport. Shield and nodes centred on (54,54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Background disc ──────────────────────────────────────────────── -->
    <path
        android:fillColor="#FF0D0C2B"
        android:pathData="M54,54m-50,0a50,50 0,1 1,100 0a50,50 0,1 1,-100 0" />

    <!-- ── Subtle outer ring accent ─────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#1A4F4BD4"
        android:strokeWidth="1"
        android:pathData="M54,54m-46,0a46,46 0,1 1,92 0a46,46 0,1 1,-92 0" />

    <!-- ── Shield outline ───────────────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C4C3EE"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="
            M54,20
            L82,34
            L82,65
            Q82,79 54,90
            Q26,79 26,65
            L26,34
            Z" />

    <!-- ── Mesh connection lines ─────────────────────────────────────────── -->
    <path
        android:strokeColor="#5ADFF0"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="
            M54,38 L54,56
            M40,64 L54,56
            M68,64 L54,56
            M54,38 L40,64
            M54,38 L68,64
            M40,64 L68,64" />

    <!-- ── Outer network nodes ───────────────────────────────────────────── -->
    <!-- Top node -->
    <path
        android:fillColor="#4F4BD4"
        android:pathData="M54,38m-5.5,0a5.5,5.5 0,1 1,11 0a5.5,5.5 0,1 1,-11 0" />
    <!-- Bottom-left node -->
    <path
        android:fillColor="#4F4BD4"
        android:pathData="M40,64m-5.5,0a5.5,5.5 0,1 1,11 0a5.5,5.5 0,1 1,-11 0" />
    <!-- Bottom-right node -->
    <path
        android:fillColor="#4F4BD4"
        android:pathData="M68,64m-5.5,0a5.5,5.5 0,1 1,11 0a5.5,5.5 0,1 1,-11 0" />

    <!-- ── Central hub — two-tone glow ──────────────────────────────────── -->
    <!-- Soft glow ring -->
    <path
        android:fillColor="#8B89F9"
        android:pathData="M54,56m-8,0a8,8 0,1 1,16 0a8,8 0,1 1,-16 0" />
    <!-- Bright inner dot -->
    <path
        android:fillColor="#C4C3EE"
        android:pathData="M54,56m-3.5,0a3.5,3.5 0,1 1,7 0a3.5,3.5 0,1 1,-7 0" />

</vector>
